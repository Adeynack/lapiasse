{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Serve",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/lapiasse",
            "cwd": "${workspaceFolder}",
            "args": [
                "serve",
            ],
            "env": {
                "GOEXPERIMENT": "jsonv2"
            }
        },
        {
            "name": "Run Serve, dry start",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/lapiasse",
            "cwd": "${workspaceFolder}",
            "args": [
                "serve",
                "--dry-start"
            ],
            "env": {
                "GOEXPERIMENT": "jsonv2"
            }
        }
    ]
}