import "@typespec/http";
import "@typespec/openapi";

using Http;
using OpenAPI;

@service(#{ title: "Finances API" })
@info(#{ version: "1.0" })
@server("http://localhost:8080", "Local development server")
namespace FinancesAPI;

// ─────────────────────────────────────────────────────────────────────────────
// Common Models & Templates
// ─────────────────────────────────────────────────────────────────────────────

alias ID = string;

model ExistingResource {
  id: ID;
  created_at: utcDateTime;
  updated_at: utcDateTime;
}

model PaginatedQuery {
  /** The page number to retrieve (1-indexed). */
  @query @minValue(1) page?: int32 = 1;

  /** The maximum number of items to return per page. */
  @query("page-size")
  @minValue(1)
  @maxValue(1000)
  pageSize?: int32 = 50;
}

// ─────────────────────────────────────────────────────────────────────────────
// Error Models (RFC 7807)
// ─────────────────────────────────────────────────────────────────────────────

enum ErrorType {
  BadRequest: "error:bad_request",
  NotFound: "error:not_found",
  Validation: "error:validation",
  InternalError: "error:internal_error",
}

/** A machine-readable format for specifying errors in HTTP API responses based on RFC 7807. */
model Error {
  /** A short, human-readable summary of the problem type. */
  title: string;

  /** The HTTP status code generated by the origin server for this occurrence of the problem. */
  @minValue(100) @maxValue(599) status: int32;

  type: ErrorType;

  /** A human-readable explanation specific to this occurrence of the problem. */
  detail?: string;
}

model FieldValidationError {
  /** The name of the invalid field. */
  field: string;

  /** A message describing why the field is invalid. */
  message: string;

  /** The validation that failed. */
  @example("len") validation: string;

  /** Additional configuration related to the validation. */
  param?: string;
}

model ValidationError {
  ...Error;

  /** A list of fields that failed validation. */
  validation_errors: FieldValidationError[];
}

// ─────────────────────────────────────────────────────────────────────────────
// Response Templates
// ─────────────────────────────────────────────────────────────────────────────

@error
model NotFoundResponse {
  @statusCode statusCode: 404;
  @body body: Error;
}

@error
model UnprocessableEntityResponse {
  @statusCode statusCode: 422;
  @body body: ValidationError;
}

// ─────────────────────────────────────────────────────────────────────────────
// Domain Models
// ─────────────────────────────────────────────────────────────────────────────

model BookProperties {
  name: string;
  default_currency_iso_code: string;
}

model Book {
  ...ExistingResource;
  ...BookProperties;
}

enum RegisterType {
  expense,
  income,
  asset,
  bank,
  card,
  institution,
  investment,
  liability,
  loan,
}

model RegisterProperties {
  name: string;
  account_type: RegisterType;
  currency_iso_code: string;
}

model Register {
  ...ExistingResource;
  ...RegisterProperties;
}

enum ExchangeStatus {
  uncleared,
  reconciling,
  cleared,
}

model ExchangeProperties {
  date: plainDate;
  register_id: ID;
  cheque?: string;
  description: string;
  memo?: string;
  status: ExchangeStatus;
}

model Exchange {
  ...ExistingResource;
  ...ExchangeProperties;
}

model SplitProperties {
  exchange_id: ID;
  destination_register_id: ID;
  amount: int64;
  counterpart_amount?: int64;
  memo?: string;
  status: ExchangeStatus;
}

model Split {
  ...ExistingResource;
  ...SplitProperties;
}

model ExchangeWithSplits {
  ...Exchange;
  splits: Split[];
}

model UserProperties {
  display_name: string;
}

model User {
  ...ExistingResource;
  ...UserProperties;
}

enum ServerHealthStatus {
  healthy,
  unhealthy,
}

// ─────────────────────────────────────────────────────────────────────────────
// API Interfaces
// ─────────────────────────────────────────────────────────────────────────────

@route("/books")
interface Books {
  @get
  @operationId("GetBooks")
  list(...PaginatedQuery): {
    @body body: {
      books: Book[];
    };
  };

  @post
  @operationId("CreateBook")
  create(
    @body body: {
      book: BookProperties;
    },
  ): {
    @statusCode statusCode: 201;
    @body body: {
      book: Book;
    };
  } | UnprocessableEntityResponse;

  @get
  @operationId("GetBook")
  @route("{bookId}")
  get(@path bookId: string): {
    @body body: {
      book: Book;
    };
  } | NotFoundResponse;
}

@route("/books/{bookId}/registers")
interface BookRegisters {
  @get
  @operationId("GetBookRegisters")
  list(@path bookId: string, ...PaginatedQuery): {
    @body body: {
      registers: Register[];
    };
  };

  @post
  @operationId("CreateBookRegister")
  create(
    @path bookId: string,
    @body body: {
      register: RegisterProperties;
    },
  ): {
    @statusCode statusCode: 201;
    @body body: {
      register: Register;
    };
  } | UnprocessableEntityResponse;
}

@route("/exchanges")
interface Exchanges {
  @get
  list(): {
    @body body: {
      exchanges: ExchangeWithSplits[];
    };
  };
}

@route("/health")
interface Health {
  @get
  check(): {
    @body body: {
      status: ServerHealthStatus;
      reason?: string;
    };
  };
}
