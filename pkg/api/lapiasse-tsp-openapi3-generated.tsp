import "@typespec/http";
import "@typespec/openapi";
import "@typespec/openapi3";

using Http;
using OpenAPI;

@service(#{ title: "La Piasse API" })
@info(#{ version: "1.0" })
@server("http://localhost:8080", "Local development server")
namespace LapiasseAPI;

/**
 * A machine-readable format for specifying errors in HTTP API responses
 * based on RFC 7807 (https://datatracker.ietf.org/doc/html/rfc7807).
 *
 */
model Error<
  Status extends integer = 500,
  Type extends string = "error:internal_error"
> {
  /** A short, human-readable summary of the problem type. */
  title: Status;

  /** The HTTP status code generated by the origin server for this occurrence of the problem. */
  status: integer;

  /** A URI reference that identifies the problem type. */
  // @format("uri-reference")
  type: Type;

  /** A human-readable explanation specific to this occurrence of the problem. */
  detail?: string;
}

model BadRequestError extends Error<400, "error:bad_request"> {}

model NotFoundError extends Error<404, "error:not_found"> {}

model ValidationError extends Error<422, "error:validation"> {
  /** A list of fields that failed validation. */
  validation_errors: FieldValidationError[];
}

model FieldValidationError {
  /** The name of the invalid field. */
  field: string;

  /** A message describing why the field is invalid. */
  message: string;

  /** The validation that failed. */
  validation: string;

  /** Additional configuration related to the validation. */
  param?: string;
}

scalar ID extends string;

/**
 * Base model for all resources.
 */
model Resource {
  @visibility(Lifecycle.Read) id: string;
  @visibility(Lifecycle.Read) created_at: utcDateTime;
  @visibility(Lifecycle.Read) updated_at: utcDateTime;
}

model Book extends Resource {
  name: string;
  default_currency_iso_code: string;
}

enum ServerHealthStatus {
  healthy,
  unhealthy,
}

enum ExchangeStatus {
  uncleared,
  reconciling,
  cleared,
}

model ExchangeWithSplits extends Exchange {
  splits: Split[];
}

model Exchange extends Resource {
  date: plainDate;
  register_id: ID;
  cheque?: string;
  description: string;
  memo?: string;
  status: ExchangeStatus;
}

@extension("x-go-type", "int64")
scalar Amount extends integer;

model Split extends Resource {
  exchange_id: ID;
  destination_register_id: ID;
  amount: Amount;
  counterpart_amount?: Amount;
  memo?: string;
  status: ExchangeStatus;
}

model User extends Resource {
  display_name: string;
}

model Register extends Resource {
  name: string;
  account_type: RegisterType;
  currency_iso_code: string;
}

enum RegisterType {
  expense,
  income,
  asset,
  bank,
  card,
  institution,
  investment,
  liability,
  loan,
}

@route("/books") @get op GetBooks(
  ...Parameters.page,
  ...Parameters.page_size,
): Body<{
  books: Book[];
}>;

@route("/books") @post op CreateBook(
  @body body: {
    book: Book;
  },
): {
  @statusCode statusCode: 201;
  @body body: {
    book: Book;
  };
} | {
  @statusCode statusCode: 422;
  @body body: ValidationError;
};

@route("/books/{bookId}") @get op GetBook(...Parameters.bookId): Body<{
  book: Book;
}> | (NotFoundResponse & Error);

@route("/books/{bookId}/registers") @get op GetBookRegisters(
  ...Parameters.bookId,
  ...Parameters.page,
  ...Parameters.page_size,
): Body<{
  registers: Register[];
}>;

@route("/books/{bookId}/registers") @post op CreateBookRegister(
  ...Parameters.bookId,
  @body body: {
    register: Register;
  },
): {
  @statusCode statusCode: 201;
  @body body: {
    register: Register;
  };
} | {
  @statusCode statusCode: 422;
  @body body: ValidationError;
};

@route("/exchanges")
@get
// FIXME: Open API operation 'GET /exchanges' is missing an operationId. Generated: 'get_exchanges'
op get_exchanges(): Body<{
  exchanges: ExchangeWithSplits[];
}>;

@route("/health")
@get
// FIXME: Open API operation 'GET /health' is missing an operationId. Generated: 'get_health'
op get_health(): Body<{
  status: ServerHealthStatus;
  reason?: string;
}>;

namespace Parameters {
  model page {
    /** The page number to retrieve (1-indexed). */
    @minValue(1) page?: integer = 1;
  }

  model page_size {
    /** The maximum number of items to return per page. */
    @minValue(1)
    @maxValue(1000)
    `page-size`?: integer = 50;
  }
  model bookId {
    @path bookId: string;
  }
}
