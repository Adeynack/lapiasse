import "@typespec/http";
import "@typespec/openapi";
import "@typespec/openapi3";

using Http;
using OpenAPI;

@service(#{ title: "La Piasse API" })
@info(#{ version: "1.0" })
@server("http://localhost:8080", "Local development server")
namespace LapiasseAPI;

/**
 * A machine-readable format for specifying errors in HTTP API responses
 * based on RFC 7807 (https://datatracker.ietf.org/doc/html/rfc7807).
 */
model Error {
  @statusCode statusCode: integer = 500;

  /** A short, human-readable summary of the problem type. */
  title: string;

  /** The HTTP status code generated by the origin server for this occurrence of the problem. */
  @example(404)
  @example(422)
  status: integer;

  /** A URI reference that identifies the problem type. */
  // @format("uri-reference")
  @example(ErrorType.NotFound)
  @example(ErrorType.Validation)
  type: ErrorType;

  /** A human-readable explanation specific to this occurrence of the problem. */
  detail?: string;
}

enum ErrorType {
  InternalError: "error:internal_error",
  BadRequest: "error:bad_request",
  NotFound: "error:not_found",
  Validation: "error:validation",
}

model InternalError extends Error {
  @statusCode statusCode: 500;
}

model BadRequestError extends Error {
  @statusCode statusCode: 400;
}

model NotFoundError extends Error {
  @statusCode statusCode: 404;
}

model ValidationError extends Error {
  @statusCode statusCode: 422;

  /** A list of fields that failed validation. */
  validation_errors: FieldValidationError[];
}

model FieldValidationError {
  /** The name of the invalid field. */
  field: string;

  /** A message describing why the field is invalid. */
  message: string;

  /** The validation that failed. */
  validation: string;

  /** Additional configuration related to the validation. */
  param?: string;
}

scalar ID extends string;

/**
 * Base model for all resources.
 */
model Resource {
  id: string;
  created_at: utcDateTime;
  updated_at: utcDateTime;
}

namespace Book {
  model Show {
    ...Resource;
    ...Create;
  }

  model Index is Show;

  model Create {
    name: string;
    default_currency_iso_code: string;
  }

  model Update is Create;
}

enum ServerHealthStatus {
  healthy,
  unhealthy,
}

enum ExchangeStatus {
  uncleared,
  reconciling,
  cleared,
}

model ExchangeWithSplits extends Exchange {
  splits: Split[];
}

model Exchange extends Resource {
  date: plainDate;
  register_id: ID;
  cheque?: string;
  description: string;
  memo?: string;
  status: ExchangeStatus;
}

@extension("x-go-type", "int64")
scalar Amount extends integer;

model Split extends Resource {
  exchange_id: ID;
  destination_register_id: ID;
  amount: Amount;
  counterpart_amount?: Amount;
  memo?: string;
  status: ExchangeStatus;
}

model User extends Resource {
  display_name: string;
}

model Register extends Resource {
  name: string;

  @removeVisibility(Lifecycle.Update)
  account_type: RegisterType;

  @removeVisibility(Lifecycle.Update)
  currency_iso_code: string;
}

enum RegisterType {
  expense,
  income,
  asset,
  bank,
  card,
  institution,
  investment,
  liability,
  loan,
}

model Health {
  status: ServerHealthStatus;
  reason?: string;
}

@route("/health") op health(): Health;

model PageResult<T> {
  items: T[];
}

model Paginated {
  /** The page number to retrieve (1-indexed). */
  @query
  @minValue(1)
  page?: integer = 1;

  /** The maximum number of items to return per page. */
  @query
  @minValue(1)
  @maxValue(1000)
  `page-size`?: integer = 50;
}

namespace Res {
  alias Show<T> = T | NotFoundError;

  alias Create<T> = {
    @statusCode statusCode: 201;
    @body body: T;
  } | ValidationError;

  alias Update<T> = T | NotFoundError | ValidationError;

  alias Delete = NoContentResponse | NotFoundError;
}

@route("/book")
interface Books {
  Index(...Paginated): PageResult<Book.Index>;

  Show(@path id: ID): Res.Show<Book.Show>;

  @post Create(@body book: Book.Create): Res.Create<Book.Show>;

  @put Update(@path id: ID, @body book: Book.Update): Res.Update<Book.Show>;

  @delete Delete(@path id: ID): Res.Delete;
}

